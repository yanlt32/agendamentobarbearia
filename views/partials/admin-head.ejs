<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="<%= settings.theme === 'light' ? 'light' : 'dark' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Painel Administrativo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body>
<div class="admin-wrapper">
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <% if (settings.logo) { %>
        <img src="<%= settings.logo %>" alt="<%= settings.shop_name %>" class="sidebar-logo-img">
        <span><%= settings.shop_name %></span>
      <% } else { %>
        <%- include('./brand-mark', { size: 'sm' }) %>
      <% } %>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="<%= currentPath.startsWith('/admin/dashboard') ? 'active' : '' %>"><i class="fa-solid fa-gauge"></i> Dashboard</a>
      <a href="/admin/appointments" class="<%= currentPath.startsWith('/admin/appointments') ? 'active' : '' %>"><i class="fa-regular fa-calendar-check"></i> Agendamentos</a>
      <a href="/admin/clients" class="<%= currentPath.startsWith('/admin/clients') ? 'active' : '' %>"><i class="fa-solid fa-users"></i> Clientes</a>
      <a href="/admin/barbers" class="<%= currentPath.startsWith('/admin/barbers') ? 'active' : '' %>"><i class="fa-solid fa-user-tie"></i> Barbeiros</a>
      <a href="/admin/services" class="<%= currentPath.startsWith('/admin/services') ? 'active' : '' %>"><i class="fa-solid fa-scissors"></i> Servicos</a>
      <a href="/admin/hours" class="<%= currentPath.startsWith('/admin/hours') ? 'active' : '' %>"><i class="fa-regular fa-clock"></i> Horarios</a>
      <a href="/admin/financial" class="<%= currentPath.startsWith('/admin/financial') ? 'active' : '' %>"><i class="fa-solid fa-sack-dollar"></i> Financeiro</a>
      <a href="/admin/backup" class="<%= currentPath.startsWith('/admin/backup') ? 'active' : '' %>"><i class="fa-solid fa-database"></i> Backup</a>
      <a href="/admin/logs" class="<%= currentPath.startsWith('/admin/logs') ? 'active' : '' %>"><i class="fa-solid fa-list-check"></i> Logs</a>
      <a href="/admin/settings" class="<%= currentPath.startsWith('/admin/settings') ? 'active' : '' %>"><i class="fa-solid fa-gear"></i> Configuracoes</a>
      <a href="/" target="_blank"><i class="fa-solid fa-arrow-up-right-from-square"></i> Ver site</a>
    </nav>
  </aside>

  <div class="admin-main">
    <header class="admin-topbar">
      <button class="btn-icon d-lg-none" id="btnToggleSidebar"><i class="fa-solid fa-bars"></i></button>
      <h5 class="mb-0 flex-grow-1"><%= title %></h5>
      <button class="btn-icon" id="btnThemeToggle" title="Alternar tema"><i class="fa-solid fa-circle-half-stroke"></i></button>
      <div class="dropdown">
        <button class="btn-icon dropdown-toggle" data-bs-toggle="dropdown">
          <i class="fa-solid fa-circle-user"></i> <%= currentUser ? currentUser.name : '' %>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><form action="/admin/logout" method="POST"><button type="submit" class="dropdown-item"><i class="fa-solid fa-right-from-bracket me-2"></i>Sair</button></form></li>
        </ul>
      </div>
    </header>

    <main class="admin-content">
      <%- include('./flash') %>
