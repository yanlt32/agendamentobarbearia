<footer class="site-footer" id="contato">
  <div class="container py-5">
    <div class="row g-4">
      <div class="col-lg-4">
        <div class="mb-3"><%- include('./brand-mark', { size: 'md' }) %></div>
        <p class="text-secondary small"><%= settings.about_text %></p>
        <div class="d-flex gap-3 mt-3">
          <a href="<%= settings.whatsapp ? 'https://wa.me/' + settings.whatsapp : '#' %>" target="_blank" class="social-icon"><i class="fa-brands fa-whatsapp"></i></a>
          <a href="<%= settings.instagram %>" target="_blank" class="social-icon"><i class="fa-brands fa-instagram"></i></a>
          <a href="<%= settings.facebook %>" target="_blank" class="social-icon"><i class="fa-brands fa-facebook"></i></a>
        </div>
      </div>
      <div class="col-lg-4">
        <h6 class="gold-text mb-3">Contato</h6>
        <p class="small mb-2"><i class="fa-solid fa-phone me-2 gold-text"></i><%= settings.phone %></p>
        <p class="small mb-2"><i class="fa-solid fa-location-dot me-2 gold-text"></i><%= settings.address %></p>
        <p class="small mb-2"><i class="fa-brands fa-whatsapp me-2 gold-text"></i>
          <a href="https://wa.me/<%= settings.whatsapp %>" target="_blank" class="footer-link">Fale conosco no WhatsApp</a>
        </p>
      </div>
      <div class="col-lg-4">
        <h6 class="gold-text mb-3">Horario de Funcionamento</h6>
        <ul class="list-unstyled small text-secondary">
          <li class="d-flex justify-content-between border-bottom border-secondary-subtle py-1"><span>Segunda - Sexta</span><span>09:00 - 19:00</span></li>
          <li class="d-flex justify-content-between border-bottom border-secondary-subtle py-1"><span>Sabado</span><span>09:00 - 17:00</span></li>
          <li class="d-flex justify-content-between py-1"><span>Domingo</span><span>Fechado</span></li>
        </ul>
      </div>
    </div>
    <hr class="border-secondary-subtle mt-4">
    <p class="text-center small text-secondary mb-0">&copy; <%= new Date().getFullYear() %> <%= settings.shop_name %>. Todos os direitos reservados.</p>
  </div>
</footer>

<a href="https://wa.me/<%= settings.whatsapp %>" target="_blank" class="whatsapp-float"><i class="fa-brands fa-whatsapp"></i></a>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/site.js"></script>
</body>
</html>
