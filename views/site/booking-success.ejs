<%- include('../partials/site-head') %>
<%- include('../partials/site-nav') %>

<section class="booking-section d-flex align-items-center" style="min-height:80vh;">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6 text-center">
        <div class="success-icon mb-4"><i class="fa-solid fa-check"></i></div>
        <h2 class="section-title mb-3">Agendamento Confirmado!</h2>
        <p class="text-secondary mb-4">Seu horario foi reservado com sucesso. Guarde o comprovante abaixo ou adicione ao seu calendario.</p>
        <div class="summary-box p-4 text-start mb-4" id="printArea">
          <p class="mb-2"><i class="fa-regular fa-calendar me-2 gold-text"></i><strong>Data:</strong> <%= appointment.date %></p>
          <p class="mb-2"><i class="fa-regular fa-clock me-2 gold-text"></i><strong>Horario:</strong> <%= appointment.time %></p>
          <p class="mb-2"><i class="fa-solid fa-scissors me-2 gold-text"></i><strong>Servico:</strong> <%= appointment.service_name %></p>
          <p class="mb-2"><i class="fa-solid fa-user me-2 gold-text"></i><strong>Barbeiro:</strong> <%= appointment.barber_name %></p>
          <p class="mb-0"><i class="fa-solid fa-tag me-2 gold-text"></i><strong>Valor:</strong> R$ <%= appointment.price.toFixed(2).replace('.', ',') %></p>
        </div>
        <div class="d-flex gap-2 justify-content-center flex-wrap mb-3 no-print">
          <a href="/agendar/<%= appointment.id %>/calendario.ics" class="btn btn-outline-light px-4">
            <i class="fa-regular fa-calendar-plus me-2"></i>Adicionar ao calendario
          </a>
        </div>
        <p class="text-secondary small mb-3 no-print">
          <i class="fa-regular fa-bell gold-text me-1"></i>Adicionando ao calendario, voce recebe um lembrete automatico 1 hora antes do horario.
        </p>
        <div class="d-flex gap-2 justify-content-center flex-wrap mb-3 no-print">
          <button type="button" class="btn btn-outline-light px-4" onclick="window.print()">
            <i class="fa-solid fa-print me-2"></i>Imprimir / salvar
          </button>
        </div>
        <a href="/" class="btn btn-gold px-4 no-print">Voltar ao inicio</a>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/site-footer') %>
