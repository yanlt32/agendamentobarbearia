<%- include('../../partials/admin-head') %>

<div class="panel mb-4">
  <form class="row g-2 align-items-end" method="GET" action="/admin/appointments">
    <div class="col-6 col-md-2">
      <label class="form-label small">Periodo</label>
      <select name="range" class="form-select form-select-sm">
        <option value="">Todos</option>
        <option value="today" <%= filters.range === 'today' ? 'selected' : '' %>>Hoje</option>
        <option value="tomorrow" <%= filters.range === 'tomorrow' ? 'selected' : '' %>>Amanha</option>
        <option value="week" <%= filters.range === 'week' ? 'selected' : '' %>>Esta semana</option>
        <option value="month" <%= filters.range === 'month' ? 'selected' : '' %>>Este mes</option>
      </select>
    </div>
    <div class="col-6 col-md-2">
      <label class="form-label small">Barbeiro</label>
      <select name="barberId" class="form-select form-select-sm">
        <option value="">Todos</option>
        <% barbers.forEach(function(b) { %>
          <option value="<%= b.id %>" <%= String(filters.barberId) === String(b.id) ? 'selected' : '' %>><%= b.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-6 col-md-2">
      <label class="form-label small">Status</label>
      <select name="status" class="form-select form-select-sm">
        <option value="">Todos</option>
        <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pendente</option>
        <option value="confirmed" <%= filters.status === 'confirmed' ? 'selected' : '' %>>Confirmado</option>
        <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Finalizado</option>
        <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelado</option>
      </select>
    </div>
    <div class="col-6 col-md-3">
      <label class="form-label small">Buscar cliente/telefone</label>
      <input type="text" name="search" class="form-control form-control-sm" value="<%= filters.search || '' %>">
    </div>
    <div class="col-6 col-md-2">
      <button class="btn btn-gold btn-sm w-100" type="submit"><i class="fa-solid fa-filter me-1"></i>Filtrar</button>
    </div>
    <div class="col-6 col-md-1">
      <a href="/admin/appointments/new" class="btn btn-outline-light btn-sm w-100" title="Novo"><i class="fa-solid fa-plus"></i></a>
    </div>
  </form>
</div>

<div class="panel">
  <div class="table-responsive d-none d-md-block">
    <table class="table table-admin align-middle">
      <thead>
        <tr>
          <th>Data</th><th>Hora</th><th>Cliente</th><th>Barbeiro</th><th>Servico</th><th>Valor</th><th>Status</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function(a) { %>
          <tr>
            <td><%= a.date %></td>
            <td><%= a.time %></td>
            <td><%= a.client_name %><br><small class="text-secondary"><%= a.client_phone %></small></td>
            <td><%= a.barber_name %></td>
            <td><%= a.service_name %></td>
            <td>R$ <%= a.price.toFixed(2).replace('.', ',') %></td>
            <td><span class="status-badge status-<%= a.status %>"><%= ({pending:'Pendente',confirmed:'Confirmado',completed:'Finalizado',cancelled:'Cancelado'})[a.status] %></span></td>
            <td class="text-end">
              <div class="dropdown">
                <button class="btn-icon" data-bs-toggle="dropdown"><i class="fa-solid fa-ellipsis-vertical"></i></button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a class="dropdown-item" href="/admin/appointments/<%= a.id %>/edit"><i class="fa-solid fa-pen me-2"></i>Editar</a></li>
                  <li>
                    <form action="/admin/appointments/<%= a.id %>/status" method="POST" class="px-3 py-1">
                      <input type="hidden" name="status" value="completed">
                      <button class="dropdown-item p-0 border-0 bg-transparent text-start" type="submit"><i class="fa-solid fa-flag-checkered me-2"></i>Finalizar atendimento</button>
                    </form>
                  </li>
                  <li>
                    <form action="/admin/appointments/<%= a.id %>/status" method="POST" class="px-3 py-1 confirm-form" data-confirm="Cancelar este agendamento?">
                      <input type="hidden" name="status" value="cancelled">
                      <button class="dropdown-item p-0 border-0 bg-transparent text-start text-warning" type="submit"><i class="fa-solid fa-ban me-2"></i>Cancelar</button>
                    </form>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <form action="/admin/appointments/<%= a.id %>/delete" method="POST" class="px-3 py-1 confirm-form" data-confirm="Excluir este agendamento permanentemente?">
                      <button class="dropdown-item p-0 border-0 bg-transparent text-start text-danger" type="submit"><i class="fa-solid fa-trash me-2"></i>Excluir</button>
                    </form>
                  </li>
                </ul>
              </div>
            </td>
          </tr>
        <% }) %>
        <% if (rows.length === 0) { %>
          <tr><td colspan="8" class="text-center text-secondary py-4">Nenhum agendamento encontrado.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- MOBILE: card list, built for a barber checking the schedule on a phone -->
  <div class="appt-cards d-md-none">
    <% if (rows.length === 0) { %>
      <p class="text-center text-secondary py-4 mb-0">Nenhum agendamento encontrado.</p>
    <% } %>
    <% rows.forEach(function(a) { %>
      <div class="appt-card">
        <div class="appt-card-top">
          <div>
            <span class="appt-card-date"><i class="fa-regular fa-calendar me-1"></i><%= a.date %></span>
            <span class="appt-card-time"><i class="fa-regular fa-clock me-1"></i><%= a.time %></span>
          </div>
          <span class="status-badge status-<%= a.status %>"><%= ({pending:'Pendente',confirmed:'Confirmado',completed:'Finalizado',cancelled:'Cancelado'})[a.status] %></span>
        </div>
        <div class="appt-card-client">
          <strong><%= a.client_name %></strong>
          <div class="appt-card-contact">
            <a href="tel:<%= a.client_phone.replace(/\D/g,'') %>" class="link-gold"><i class="fa-solid fa-phone me-1"></i><%= a.client_phone %></a>
            <a href="https://wa.me/55<%= a.client_phone.replace(/\D/g,'') %>" target="_blank" class="link-gold ms-3"><i class="fa-brands fa-whatsapp me-1"></i>WhatsApp</a>
          </div>
        </div>
        <div class="appt-card-meta">
          <span><i class="fa-solid fa-scissors me-1"></i><%= a.service_name %></span>
          <span><i class="fa-solid fa-user-tie me-1"></i><%= a.barber_name %></span>
          <span class="gold-text fw-semibold">R$ <%= a.price.toFixed(2).replace('.', ',') %></span>
        </div>
        <div class="appt-card-actions">
          <form action="/admin/appointments/<%= a.id %>/status" method="POST" class="flex-fill">
            <input type="hidden" name="status" value="completed">
            <button class="btn btn-gold btn-sm w-100" type="submit"><i class="fa-solid fa-flag-checkered me-1"></i>Finalizar</button>
          </form>
          <div class="dropdown">
            <button class="btn-icon" data-bs-toggle="dropdown"><i class="fa-solid fa-ellipsis-vertical"></i></button>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/admin/appointments/<%= a.id %>/edit"><i class="fa-solid fa-pen me-2"></i>Editar</a></li>
              <li>
                <form action="/admin/appointments/<%= a.id %>/status" method="POST" class="px-3 py-1 confirm-form" data-confirm="Cancelar este agendamento?">
                  <input type="hidden" name="status" value="cancelled">
                  <button class="dropdown-item p-0 border-0 bg-transparent text-start text-warning" type="submit"><i class="fa-solid fa-ban me-2"></i>Cancelar</button>
                </form>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <form action="/admin/appointments/<%= a.id %>/delete" method="POST" class="px-3 py-1 confirm-form" data-confirm="Excluir este agendamento permanentemente?">
                  <button class="dropdown-item p-0 border-0 bg-transparent text-start text-danger" type="submit"><i class="fa-solid fa-trash me-2"></i>Excluir</button>
                </form>
              </li>
            </ul>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <% if (totalPages > 1) { %>
    <nav class="mt-3">
      <ul class="pagination pagination-sm justify-content-center">
        <% for (let p = 1; p <= totalPages; p++) { %>
          <li class="page-item <%= p === page ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= p %>&range=<%= filters.range || '' %>&barberId=<%= filters.barberId || '' %>&status=<%= filters.status || '' %>&search=<%= filters.search || '' %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>

<%- include('../../partials/admin-footer') %>
