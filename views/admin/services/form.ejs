<%- include('../../partials/admin-head') %>

<div class="panel" style="max-width:640px;">
  <form action="<%= service ? '/admin/services/' + service.id : '/admin/services' %>" method="POST">
    <div class="row g-3">
      <div class="col-12">
        <label class="form-label">Nome *</label>
        <input type="text" name="name" class="form-control" required value="<%= service ? service.name : '' %>">
      </div>
      <div class="col-12">
        <label class="form-label">Descricao</label>
        <textarea name="description" class="form-control" rows="2"><%= service ? (service.description || '') : '' %></textarea>
      </div>
      <div class="col-md-4">
        <label class="form-label">Preco (R$) *</label>
        <input type="number" step="0.01" min="0" name="price" class="form-control" required value="<%= service ? service.price : '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Duracao (min) *</label>
        <input type="number" min="5" step="5" name="duration_minutes" class="form-control" required value="<%= service ? service.duration_minutes : 30 %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Categoria</label>
        <input type="text" name="category" class="form-control" list="categoryList" value="<%= service ? (service.category || '') : '' %>">
        <datalist id="categoryList">
          <option value="Corte"><option value="Barba"><option value="Pigmentacao"><option value="Sobrancelha"><option value="Combo">
        </datalist>
      </div>
      <div class="col-12">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="active" id="activeCheck" <%= !service || service.active ? 'checked' : '' %>>
          <label class="form-check-label" for="activeCheck">Servico ativo</label>
        </div>
      </div>
    </div>
    <div class="d-flex gap-2 mt-4">
      <button type="submit" class="btn btn-gold">Salvar</button>
      <a href="/admin/services" class="btn btn-outline-light">Cancelar</a>
    </div>
  </form>
</div>

<%- include('../../partials/admin-footer') %>
